--3
select nom from communes where dep_id=8 intersect select nom from communes where population>=10;

--4
select * from (select nom from communes where dep_id=8 intersect select nom from communes where population>=10) order by nom ASC;

--5
select nom from (select nom,population from communes where dep_id=8 intersect select nom,population from communes where population>=10) order by population DESC;

--6
