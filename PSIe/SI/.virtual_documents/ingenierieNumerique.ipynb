def cicularite(xC, yC, R, xG, yG):
    listeEcarts = []

    for i in range(len(xG)):
        Ei = sqrt((xG[i]-xC)**2+(yG[i]-yC)**2) - R
        listeEcarts.append(Ei)

    Emax, Emin = max(listeEcarts), min(listeEcarts)

    return Emin, Emax

Emin, Emax = cicularite(xC, yC, D/2, xG, yG)

