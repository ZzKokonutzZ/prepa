# Compiler le code

from numpy import sqrt

def cercle(x,y):
    Sxi, Syi, Sxiyi, Sxi2, Syi2, Sxiyi2, Sxi2yi, Sxi3, Syi3 = 0, 0, 0, 0, 0, 0, 0, 0, 0

    n = len(x)

    for i in range(n):
        Sxi    += x[i]
        Syi    += y[i]
        Sxiyi  += x[i]*y[i]
        Sxi2   += x[i]**2
        Syi2   += y[i]**2
        Sxiyi2 += x[i]*(y[i]**2)
        Sxi2yi += (x[i]**2)*y[i]
        Sxi3   += x[i]**3
        Syi3   += y[i]**3

    a = Sxi2-((Sxi**2)/n)
    b = Sxiyi-(Sxi*Syi/n)
    c = Syi2-((Syi**2)/n)
    d = (Sxi3+Sxiyi2-(Sxi*(Sxi2+Syi2)/n))/2
    e = (Syi3+Sxi2yi-(Syi*(Sxi2+Syi2)/n))/2

    xC = (c*d-b*e)/(a*c-b**2)
    yC = (a*e-b*d)/(a*c-b**2)
    R = sqrt(((Sxi2+Syi2-2*(xC*Sxi+yC*Syi))/n)+xC**2+yC**2)

    return xC, yC, 2*R

xC, yC, D = cercle(xG,yG)

