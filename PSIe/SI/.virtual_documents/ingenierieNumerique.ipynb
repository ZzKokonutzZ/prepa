def dicho(t_ref,theta_ref,Cr_min=0,Cr_max=0.03,ED=thetaEDCr) :
    while Cr_max-Cr_min>10**-5 :
        Cr=(Cr_max+Cr_min)/2
        tED,thetaED=ED(Cr)
        dist=ecartCumul(t_ref,theta_ref,tED,thetaED)
        if dist==0 :
            return Cr
        elif dist<0 :
            Cr_min=Cr
        else :
            Cr_max=Cr
    return Cr
